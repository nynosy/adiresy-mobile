<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Error state -->
    <LinearLayout
        android:id="@+id/error_group"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/label_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_retry" />

    </LinearLayout>

    <!-- Content state -->
    <ScrollView
        android:id="@+id/content_group"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Code + hierarchy (left) and QR code (right) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">

                    <!-- "Your address code" headline -->
                    <TextView
                        android:id="@+id/label_code_headline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_code_headline"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginBottom="2dp" />

                    <!-- Address code — large, primary colour, auto-sized to fit beside the QR code -->
                    <TextView
                        android:id="@+id/label_code"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="?attr/colorPrimary"
                        android:maxLines="1"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="14sp"
                        android:autoSizeMaxTextSize="24sp"
                        android:autoSizeStepGranularity="1sp" />

                </LinearLayout>

                <!-- QR code — fixed light background regardless of app theme, for scan contrast -->
                <ImageView
                    android:id="@+id/image_qr_code"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@android:color/white"
                    android:padding="4dp"
                    android:contentDescription="@string/cd_qr_code" />

            </LinearLayout>

            <!-- Admin hierarchy card: Fokontany / Commune (code) / District (code) / Région -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout style="@style/CodeDetail.HierarchyRow">
                        <TextView
                            style="@style/CodeDetail.HierarchyRow.Label"
                            android:text="@string/label_fokontany" />
                        <TextView
                            android:id="@+id/value_fokontany"
                            style="@style/CodeDetail.HierarchyRow.Value" />
                    </LinearLayout>

                    <LinearLayout style="@style/CodeDetail.HierarchyRow">
                        <TextView
                            style="@style/CodeDetail.HierarchyRow.Label"
                            android:text="@string/label_commune" />
                        <TextView
                            android:id="@+id/value_commune"
                            style="@style/CodeDetail.HierarchyRow.Value" />
                    </LinearLayout>

                    <LinearLayout style="@style/CodeDetail.HierarchyRow">
                        <TextView
                            style="@style/CodeDetail.HierarchyRow.Label"
                            android:text="@string/label_district" />
                        <TextView
                            android:id="@+id/value_district"
                            style="@style/CodeDetail.HierarchyRow.Value" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/CodeDetail.HierarchyRow"
                        android:layout_marginBottom="0dp">
                        <TextView
                            style="@style/CodeDetail.HierarchyRow.Label"
                            android:text="@string/label_region" />
                        <TextView
                            android:id="@+id/value_region"
                            style="@style/CodeDetail.HierarchyRow.Value" />
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- GPS coordinates card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_gps_coordinates"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/value_latitude"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/value_longitude"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_share"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/btn_share" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_copy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_copy"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_navigate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_navigate"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navigate_external_hint"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?android:attr/textColorSecondary"
                android:gravity="center" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
