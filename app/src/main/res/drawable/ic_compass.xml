<?xml version="1.0" encoding="utf-8"?>
<!-- Compact compass needle: red = north, grey = south -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="28dp"
    android:height="28dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- North arrow (red, points up) -->
    <path
        android:fillColor="#D32F2F"
        android:pathData="M12,2 L8,12 L12,10 L16,12 Z" />

    <!-- South arrow (grey, points down) -->
    <path
        android:fillColor="#9E9E9E"
        android:pathData="M12,22 L8,12 L12,14 L16,12 Z" />

</vector>
