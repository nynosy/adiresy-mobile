<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Splash activity: full-screen teal so the window is never blank during cold start -->
    <style name="Theme.AdiresyMobile.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/teal_600</item>
        <item name="android:statusBarColor">@color/teal_600</item>
        <item name="android:navigationBarColor">@color/teal_600</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
    </style>

<style name="Theme.AdiresyMobile" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/teal_600</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/teal_700</item>
        <!-- Secondary -->
        <item name="colorSecondary">@color/teal_500</item>
        <item name="colorOnSecondary">@color/teal_on_secondary_light</item>
        <!-- Background & surface -->
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/slate_100</item>
        <item name="colorOnSurface">@color/slate_900</item>
        <item name="colorOnSurfaceVariant">@color/slate_600</item>
        <!-- Outline & error -->
        <item name="colorOutline">@color/slate_200</item>
        <item name="colorError">@color/red_600</item>
        <item name="colorOnError">@color/white</item>
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/teal_700</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Code Detail — admin hierarchy card rows -->
    <style name="CodeDetail.HierarchyRow" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="CodeDetail.HierarchyRow.Label">
        <item name="android:layout_width">96dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAppearance">?attr/textAppearanceLabelMedium</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
    </style>

    <style name="CodeDetail.HierarchyRow.Value">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textAppearance">?attr/textAppearanceBodyMedium</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
