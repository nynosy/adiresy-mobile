<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AdiresyMobile" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/teal_500</item>
        <item name="colorOnPrimary">@color/teal_900</item>
        <item name="colorPrimaryContainer">@color/teal_700</item>
        <!-- Secondary -->
        <item name="colorSecondary">@color/teal_500</item>
        <item name="colorOnSecondary">@color/teal_900</item>
        <!-- Background & surface -->
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="colorSurface">@color/slate_800</item>
        <item name="colorSurfaceVariant">@color/slate_700</item>
        <item name="colorOnSurface">@color/slate_200</item>
        <item name="colorOnSurfaceVariant">@color/slate_400</item>
        <!-- Outline & error -->
        <item name="colorOutline">@color/slate_700</item>
        <item name="colorError">@color/red_400</item>
        <item name="colorOnError">@color/slate_900</item>
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>
</resources>
