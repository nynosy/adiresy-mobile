    <!-- Location permission rationale -->
    <string name="location_rationale_body">Adiresy a besoin de votre position pour trouver les bâtiments à proximité. Vos coordonnées GPS sont envoyées à l\'API adiresy.mg pour rechercher les bâtiments proches de vous. Elles ne sont pas conservées au-delà de la requête et ne sont pas partagées avec des tiers.</string>
    <string name="btn_grant_permission">Autoriser</string>
    <string name="location_failed_outdoors">Signal faible — réessayez à l\'extérieur</string>
    <string name="location_permission_denied">Autorisation de localisation refusée — activez-la dans les Paramètres</string>
    <string name="btn_open_settings">Ouvrir les Paramètres</string>

    <!-- Privacy screen -->
    <string name="title_privacy">Confidentialité</string>
    <string name="privacy_body">Cette application ne nécessite pas de compte et ne collecte aucune donnée analytique. Lors de la recherche de bâtiments à proximité, vos coordonnées GPS sont envoyées à l\'API adiresy.mg — elles ne sont pas conservées au-delà de la durée de la requête et ne sont pas partagées avec des tiers. Les données cartographiques et d\'adresses en cache sont stockées localement sur votre appareil et peuvent être supprimées à tout moment dans Paramètres → Données hors ligne.</string>

